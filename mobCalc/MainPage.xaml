<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="mobCalc.MainPage"
             BackgroundColor="#1a1a1a">

    <Grid RowDefinitions="Auto,*" Padding="10">

        <!-- Display -->
        <VerticalStackLayout Grid.Row="0" Margin="0,20,0,10">
            <Label x:Name="lblHistorico" 
                   Text="" 
                   TextColor="#9c9c9c" 
                   FontSize="18"
                   HorizontalTextAlignment="End"/>
            <Label x:Name="lblDisplay" 
                   Text="0" 
                   TextColor="White" 
                   FontSize="48"
                   HorizontalTextAlignment="End"/>
        </VerticalStackLayout>

        <!-- Botões -->
        <Grid Grid.Row="1" 
              RowDefinitions="*,*,*,*,*,*"
              ColumnDefinitions="*,*,*,*"
              RowSpacing="4"
              ColumnSpacing="4">

        </Grid>

    </Grid>

</ContentPage>