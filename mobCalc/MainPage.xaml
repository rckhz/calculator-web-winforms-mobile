<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="mobCalc.MainPage"
             BackgroundColor="#000000">

    <Grid RowDefinitions="*,Auto" Padding="12">

        <!-- Display -->
        <VerticalStackLayout Grid.Row="0" VerticalOptions="End" Margin="0,0,0,20">
            <Label x:Name="lblHistorico" 
                   Text="" 
                   TextColor="#9c9c9c" 
                   FontSize="22"
                   HorizontalTextAlignment="End"/>
            <Label x:Name="lblDisplay" 
                   Text="0" 
                   TextColor="White" 
                   FontSize="70"
                   FontAttributes="None"
                   HorizontalTextAlignment="End"/>
        </VerticalStackLayout>

        <!-- Botões -->
        <Grid Grid.Row="1"
              RowDefinitions="Auto,Auto,Auto,Auto,Auto"
              ColumnDefinitions="*,*,*,*"
              RowSpacing="12"
              ColumnSpacing="12">

            <!-- Linha 1 -->
            <Button Grid.Row="0" Grid.Column="0" Text="⌫"
                    BackgroundColor="#A5A5A5" TextColor="Black"
                    CornerRadius="50" HeightRequest="80"
                    FontSize="22" Clicked="OnBtnClicked"/>
            <Button Grid.Row="0" Grid.Column="1" Text="AC"
                    BackgroundColor="#A5A5A5" TextColor="Black"
                    CornerRadius="50" HeightRequest="80"
                    FontSize="22" Clicked="OnBtnClicked"/>
            <Button Grid.Row="0" Grid.Column="2" Text="%"
                    BackgroundColor="#A5A5A5" TextColor="Black"
                    CornerRadius="50" HeightRequest="80"
                    FontSize="22" Clicked="OnBtnClicked"/>
            <Button Grid.Row="0" Grid.Column="3" Text="÷"
                    BackgroundColor="#FF9F0A" TextColor="White"
                    CornerRadius="50" HeightRequest="80"
                    FontSize="28" Clicked="OnBtnClicked"/>


            <!-- Linha 2 -->
            <Button Grid.Row="1" Grid.Column="0" Text="7"
                    BackgroundColor="#333333" TextColor="White"
                    CornerRadius="50" HeightRequest="80"
                    FontSize="28" Clicked="OnBtnClicked"/>
            <Button Grid.Row="1" Grid.Column="1" Text="8"
                    BackgroundColor="#333333" TextColor="White"
                    CornerRadius="50" HeightRequest="80"
                    FontSize="28" Clicked="OnBtnClicked"/>
            <Button Grid.Row="1" Grid.Column="2" Text="9"
                    BackgroundColor="#333333" TextColor="White"
                    CornerRadius="50" HeightRequest="80"
                    FontSize="28" Clicked="OnBtnClicked"/>
            <Button Grid.Row="1" Grid.Column="3" Text="×"
                    BackgroundColor="#FF9F0A" TextColor="White"
                    CornerRadius="50" HeightRequest="80"
                    FontSize="28" Clicked="OnBtnClicked"/>

            <!-- Linha 3 -->
            <Button Grid.Row="2" Grid.Column="0" Text="4"
                    BackgroundColor="#333333" TextColor="White"
                    CornerRadius="50" HeightRequest="80"
                    FontSize="28" Clicked="OnBtnClicked"/>
            <Button Grid.Row="2" Grid.Column="1" Text="5"
                    BackgroundColor="#333333" TextColor="White"
                    CornerRadius="50" HeightRequest="80"
                    FontSize="28" Clicked="OnBtnClicked"/>
            <Button Grid.Row="2" Grid.Column="2" Text="6"
                    BackgroundColor="#333333" TextColor="White"
                    CornerRadius="50" HeightRequest="80"
                    FontSize="28" Clicked="OnBtnClicked"/>
            <Button Grid.Row="2" Grid.Column="3" Text="−"
                    BackgroundColor="#FF9F0A" TextColor="White"
                    CornerRadius="50" HeightRequest="80"
                    FontSize="28" Clicked="OnBtnClicked"/>

            <!-- Linha 4 -->
            <Button Grid.Row="3" Grid.Column="0" Text="1"
                    BackgroundColor="#333333" TextColor="White"
                    CornerRadius="50" HeightRequest="80"
                    FontSize="28" Clicked="OnBtnClicked"/>
            <Button Grid.Row="3" Grid.Column="1" Text="2"
                    BackgroundColor="#333333" TextColor="White"
                    CornerRadius="50" HeightRequest="80"
                    FontSize="28" Clicked="OnBtnClicked"/>
            <Button Grid.Row="3" Grid.Column="2" Text="3"
                    BackgroundColor="#333333" TextColor="White"
                    CornerRadius="50" HeightRequest="80"
                    FontSize="28" Clicked="OnBtnClicked"/>
            <Button Grid.Row="3" Grid.Column="3" Text="+"
                    BackgroundColor="#FF9F0A" TextColor="White"
                    CornerRadius="50" HeightRequest="80"
                    FontSize="28" Clicked="OnBtnClicked"/>


            <!-- Linha 5 -->
            <Button Grid.Row="4" Grid.Column="0" Text="+/-"
                    BackgroundColor="#333333" TextColor="White"
                    CornerRadius="50" HeightRequest="80"
                    FontSize="22" Clicked="OnBtnClicked"/>
            <Button Grid.Row="4" Grid.Column="1" Text="0"
                    BackgroundColor="#333333" TextColor="White"
                    CornerRadius="50" HeightRequest="80"
                    FontSize="28" Clicked="OnBtnClicked"/>
            <Button Grid.Row="4" Grid.Column="2" Text="."
                    BackgroundColor="#333333" TextColor="White"
                    CornerRadius="50" HeightRequest="80"
                    FontSize="28" Clicked="OnBtnClicked"/>
            <Button Grid.Row="4" Grid.Column="3" Text="="
                    BackgroundColor="#FF9F0A" TextColor="White"
                    CornerRadius="50" HeightRequest="80"
                    FontSize="28" Clicked="OnBtnClicked"/>

        </Grid>
        
    </Grid>

</ContentPage>